<mujoco model="aliengo_with_z1_gripper">
  <compiler angle="radian" meshdir="assets" autolimits="true" />

  <option cone="elliptic" impratio="100" />

    <default>
        <!-- Aliengo 默认类 -->
        <default class="aliengo">
            <geom contype="1" conaffinity="1" friction="0.6 0.3 0.3"  margin="0.001" group="0"/>
            <joint damping="0.1" armature="0.1" frictionloss="0.2" />
        </default>

        <!-- Z1 默认类 -->
        <default class="z1">
            <joint damping="1.0" frictionloss="0.0"/>
            <default class="visual_z1">
                <geom type="mesh" group="2" contype="0" conaffinity="0"/>
            </default>
            <default class="collision_z1">
                <geom type="cylinder" group="3" mass="0" density="0"/>
                <default class="z1_gripper_stator_collision">
                    <geom pos="0.051 0 0" type="mesh"/>
                </default>
                <default class="z1_gripper_stator_pad_collision_1">
                    <geom type="box" size="0.014 0.015 0.004" pos="0.186 -0.015 -0.0125"/>
                </default>
                <default class="z1_gripper_stator_pad_collision_2">
                    <geom type="box" size="0.014 0.015 0.004" pos="0.186 0.015 -0.0125"/>
                </default>
                <default class="z1_gripper_mover_collision">
                    <geom type="mesh"/>
                </default>
                <default class="z1_gripper_mover_pad_collision_1">
                    <geom type="box" size="0.014 0.015 0.004" pos="0.086 -0.015 -0.0055"/>
                </default>
                <default class="z1_gripper_mover_pad_collision_2">
                    <geom type="box" size="0.014 0.015 0.004" pos="0.086 0.015 -0.0055"/>
                </default>
            </default>
        </default>
    </default>

    <asset>
        <!-- Aliengo Meshes -->
        <mesh name="trunk" file="trunk.stl" />
        <mesh name="hip" file="hip.stl" />
        <mesh name="thigh_mirror" file="thigh_mirror.stl" />
        <mesh name="calf" file="calf.stl" />
        <mesh name="thigh" file="thigh.stl" />
        
        <!-- Z1 Meshes -->
        <mesh name="z1_Link00" file="z1_Link00.stl"/>
        <mesh name="z1_Link01" file="z1_Link01.stl"/>
        <mesh name="z1_Link02" file="z1_Link02.stl"/>
        <mesh name="z1_Link03" file="z1_Link03.stl"/>
        <mesh name="z1_Link04" file="z1_Link04.stl"/>
        <mesh name="z1_Link05" file="z1_Link05.stl"/>
        <mesh name="z1_Link06" file="z1_Link06.stl"/>
        <mesh name="z1_GripperStator" file="z1_GripperStator.stl"/>
        <mesh name="z1_GripperStator_col_1" file="z1_GripperStator_col_1.stl"/>
        <mesh name="z1_GripperStator_col_2" file="z1_GripperStator_col_2.stl"/>
        <mesh name="z1_GripperStator_col_3" file="z1_GripperStator_col_3.stl"/>
        <mesh name="z1_GripperStator_col_4" file="z1_GripperStator_col_4.stl"/>
        <mesh name="z1_GripperStator_col_5" file="z1_GripperStator_col_5.stl"/>
        <mesh name="z1_GripperStator_col_6" file="z1_GripperStator_col_6.stl"/>
        <mesh name="z1_GripperMover" file="z1_GripperMover.stl"/>
        <mesh name="z1_GripperMover_col_1" file="z1_GripperMover_col_1.stl"/>
        <mesh name="z1_GripperMover_col_2" file="z1_GripperMover_col_2.stl"/>
        <mesh name="z1_GripperMover_col_3" file="z1_GripperMover_col_3.stl"/>
        <mesh name="z1_GripperMover_col_4" file="z1_GripperMover_col_4.stl"/>
        <mesh name="z1_GripperMover_col_5" file="z1_GripperMover_col_5.stl"/>
    </asset>

    <worldbody>
        <light directional="true" diffuse=".8 .8 .8" pos="0 0 10" dir="0 0 -10"/>

        <body name="trunk" pos="0 0 0.6" childclass="aliengo">
            <inertial pos="0.00846406 0.00404455 -0.000762916" quat="-3.12625e-05 0.708321 0.00247254 0.705886" mass="9.042" diaginertia="0.174706 0.161175 0.033357" />
            <joint type="free" />
            <geom type="mesh" contype="0" conaffinity="0" group="1" rgba="0.2 0.2 0.2 1" mesh="trunk" />
            <geom size="0.18 0.075 0.056" type="box" rgba="0.2 0.2 0.2 0" />
            <site name="imu" pos="0 0 0"/>

            <!-- Aliengo Legs -->
            <body name="FL_hip" pos="0.2399 0.051 0">
                <joint name="FL_hip_joint" axis="1 0 0" range="-1.22173 1.22173" />
                <geom type="mesh" mesh="hip" />
                <body name="FL_thigh" pos="0 0.083 0">
                    <joint name="FL_thigh_joint" axis="0 1 0" />
                    <geom type="mesh" mesh="thigh" />
                    <body name="FL_calf" pos="0 0 -0.25">
                        <joint name="FL_calf_joint" axis="0 1 0" range="-2.77507 -0.645772" />
                        <geom type="mesh" mesh="calf" />
                        <geom size="0.0265" pos="0 0 -0.25" rgba="0 0 0 1" />
                    </body>
                </body>
            </body>

            <body name="FR_hip" pos="0.2399 -0.051 0">
                <joint name="FR_hip_joint" axis="1 0 0" range="-1.22173 1.22173" />
                <geom quat="0 1 0 0" type="mesh" mesh="hip" />
                <body name="FR_thigh" pos="0 -0.083 0">
                    <joint name="FR_thigh_joint" axis="0 1 0" />
                    <geom type="mesh" mesh="thigh_mirror" />
                    <body name="FR_calf" pos="0 0 -0.25">
                        <joint name="FR_calf_joint" axis="0 1 0" range="-2.77507 -0.645772" />
                        <geom type="mesh" mesh="calf" />
                        <geom size="0.0265" pos="0 0 -0.25" rgba="0 0 0 1" />
                    </body>
                </body>
            </body>

            <body name="RL_hip" pos="-0.2399 0.051 0">
                <joint name="RL_hip_joint" axis="1 0 0" range="-1.22173 1.22173" />
                <geom quat="0 0 1 0" type="mesh" mesh="hip" />
                <body name="RL_thigh" pos="0 0.083 0">
                    <joint name="RL_thigh_joint" axis="0 1 0" />
                    <geom type="mesh" mesh="thigh" />
                    <body name="RL_calf" pos="0 0 -0.25">
                        <joint name="RL_calf_joint" axis="0 1 0" range="-2.77507 -0.645772" />
                        <geom type="mesh" mesh="calf" />
                        <geom size="0.0265" pos="0 0 -0.25" rgba="0 0 0 1" />
                    </body>
                </body>
            </body>

            <body name="RR_hip" pos="-0.2399 -0.051 0">
                <joint name="RR_hip_joint" axis="1 0 0" range="-1.22173 1.22173" />
                <geom quat="0 0 0 -1" type="mesh" mesh="hip" />
                <body name="RR_thigh" pos="0 -0.083 0">
                    <joint name="RR_thigh_joint" axis="0 1 0" />
                    <geom type="mesh" mesh="thigh_mirror" />
                    <body name="RR_calf" pos="0 0 -0.25">
                        <joint name="RR_calf_joint" axis="0 1 0" range="-2.77507 -0.645772" />
                        <geom type="mesh" mesh="calf" />
                        <geom size="0.0265" pos="0 0 -0.25" rgba="0 0 0 1" />
                    </body>
                </body>
            </body>


            <!-- ======================================================================================= -->
            <!-- Z1 机械臂安装 (带夹爪) -->
            <!-- ======================================================================================= -->
            <body name="z1_link00" pos="0.15 0 0.056" childclass="z1">
                <inertial pos="-0.00334984 -0.00013615 0.0249584" quat="-0.00692194 0.682592 0.00133293 0.730766" mass="0.472475" diaginertia="0.000531375 0.000415207 0.000378658"/>
                <geom class="visual_z1" mesh="z1_Link00"/>
                <geom size="0.0325 0.0255" pos="0 0 0.0255" class="collision_z1"/>
                <body name="z1_link01" pos="0 0 0.0585">
                    <joint name="joint1" axis="0 0 1" range="-2.61799 2.61799"/>
                    <geom class="visual_z1" mesh="z1_Link01"/>
                    <body name="z1_link02" pos="0 0 0.045">
                        <joint name="joint2" axis="0 1 0" range="0 2.96706" damping="2"/>
                        <geom class="visual_z1" mesh="z1_Link02"/>
                        <body name="z1_link03" pos="-0.35 0 0">
                            <joint name="joint3" axis="0 1 0" range="-2.87979 0"/>
                            <geom class="visual_z1" mesh="z1_Link03"/>
                            <body name="z1_link04" pos="0.218 0 0.057">
                                <joint name="joint4" axis="0 1 0" range="-1.51844 1.51844"/>
                                <geom class="visual_z1" mesh="z1_Link04"/>
                                <body name="z1_link05" pos="0.07 0 0">
                                    <joint name="joint5" axis="0 0 1" range="-1.3439 1.3439"/>
                                    <geom class="visual_z1" mesh="z1_Link05"/>
                                    <body name="z1_link06" pos="0.0492 0 0">
                                        <joint name="joint6" axis="1 0 0" range="-2.79253 2.79253"/>
                                        <geom class="visual_z1" mesh="z1_Link06"/>
                                        <!-- 夹爪部分 -->
                                        <geom pos="0.051 0 0" type="mesh" mesh="z1_GripperStator" class="visual_z1"/>
                                        <geom class="z1_gripper_stator_collision" mesh="z1_GripperStator_col_1"/>
                                        <geom class="z1_gripper_stator_collision" mesh="z1_GripperStator_col_2"/>
                                        <geom class="z1_gripper_stator_collision" mesh="z1_GripperStator_col_3"/>
                                        <geom class="z1_gripper_stator_collision" mesh="z1_GripperStator_col_4"/>
                                        <geom class="z1_gripper_stator_collision" mesh="z1_GripperStator_col_5"/>
                                        <geom class="z1_gripper_stator_collision" mesh="z1_GripperStator_col_6"/>
                                        <geom class="z1_gripper_stator_pad_collision_1"/>
                                        <geom class="z1_gripper_stator_pad_collision_2"/>
                                        <body name="gripperMover" pos="0.1 0 0">
                                            <geom type="mesh" mesh="z1_GripperMover" class="visual_z1"/>
                                            <geom class="z1_gripper_mover_collision" mesh="z1_GripperMover_col_1"/>
                                            <geom class="z1_gripper_mover_collision" mesh="z1_GripperMover_col_2"/>
                                            <geom class="z1_gripper_mover_collision" mesh="z1_GripperMover_col_3"/>
                                            <geom class="z1_gripper_mover_collision" mesh="z1_GripperMover_col_4"/>
                                            <geom class="z1_gripper_mover_collision" mesh="z1_GripperMover_col_5"/>
                                            <geom class="z1_gripper_mover_pad_collision_1"/>
                                            <geom class="z1_gripper_mover_pad_collision_2"/>
                                        </body>
                                    </body>
                                </body>
                            </body>
                        </body>
                    </body>
                </body>
            </body>
            <!-- ======================================================================================= -->


        </body>
    </worldbody>

    <actuator>       
        <!-- Aliengo Motors -->
        <motor class="aliengo" name="FL_hip" joint="FL_hip_joint" ctrlrange= "-80.0 80.0"/>
        <motor class="aliengo" name="FL_thigh" joint="FL_thigh_joint" ctrlrange= "-80.0 80.0"/>
        <motor class="aliengo" name="FL_calf" joint="FL_calf_joint" ctrlrange= "-80.0 80.0"/>
        <motor class="aliengo" name="FR_hip" joint="FR_hip_joint" ctrlrange= "-80.0 80.0"/>
        <motor class="aliengo" name="FR_thigh" joint="FR_thigh_joint" ctrlrange= "-80.0 80.0"/>
        <motor class="aliengo" name="FR_calf" joint="FR_calf_joint" ctrlrange= "-80.0 80.0"/>
        <motor class="aliengo" name="RL_hip" joint="RL_hip_joint" ctrlrange= "-80.0 80.0"/>
        <motor class="aliengo" name="RL_thigh" joint="RL_thigh_joint" ctrlrange= "-80.0 80.0"/>
        <motor class="aliengo" name="RL_calf" joint="RL_calf_joint" ctrlrange= "-80.0 80.0"/>
        <motor class="aliengo" name="RR_hip" joint="RR_hip_joint" ctrlrange= "-80.0 80.0"/>
        <motor class="aliengo" name="RR_thigh" joint="RR_thigh_joint" ctrlrange= "-80.0 80.0"/>
        <motor class="aliengo" name="RR_calf" joint="RR_calf_joint" ctrlrange= "-80.0 80.0" />

        <!-- Z1 Motors -->
        <motor class="z1" name="z1_motor1" joint="joint1" ctrlrange= "-40.0 40.0"/>
        <motor class="z1" name="z1_motor2" joint="joint2" ctrlrange="-40.0 40.0" />
        <motor class="z1" name="z1_motor3" joint="joint3" ctrlrange="-20.0 20.0"/>
        <motor class="z1" name="z1_motor4" joint="joint4" ctrlrange="-10.0 10.0"/>
        <motor class="z1" name="z1_motor5" joint="joint5" ctrlrange="-5.0 5.0"/>
        <motor class="z1" name="z1_motor6" joint="joint6" ctrlrange="-5.0 5.0"/>
    </actuator>

    <sensor>
        <jointpos name="FR_hip_pos" joint="FR_hip_joint"/>
        <jointpos name="FR_thigh_pos" joint="FR_thigh_joint"/>
        <jointpos name="FR_calf_pos" joint="FR_calf_joint"/>
        <accelerometer name="Body_Acc" site="imu"/>
        <gyro name="Body_Gyro" site="imu"/>
        <framequat name="Body_Quat" objtype="site" objname="imu"/>
    </sensor>
</mujoco>