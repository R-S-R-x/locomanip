<mujoco model="b2_with_z1_gripper">
  <compiler angle="radian" meshdir="assets" autolimits="true"/>

  <option cone="elliptic" impratio="100" />

  <default>
    <!-- B2 默认参数 -->
    <default class="b2">
      <geom type="mesh"/>
      <joint damping="0.1" armature="0.1" frictionloss="0.1"/> 
      <default class="visual_b2">
        <geom contype="0" conaffinity="0" group="2"/>
      </default>
      <default class="collision_b2">
        <geom group="3" mass="0" density="0"/>
      </default>
      <site size="0.001" rgba="0.5 0.5 0.5 0.3" group="4"/>
    </default>

    <!-- Z1 机械臂与夹爪默认参数 -->
    <default class="z1">
      <joint damping="1" frictionloss="1"/>
      <default class="visual_z1">
        <geom type="mesh" group="2" contype="0" conaffinity="0"/>
      </default>
      <default class="collision_z1">
        <geom type="cylinder" group="3" mass="0" density="0"/>
        <default class="z1_gripper_stator_collision">
          <geom pos="0.051 0 0" type="mesh"/>
        </default>
        <default class="z1_gripper_stator_pad_collision_1">
          <geom type="box" size="0.014 0.015 0.004" pos="0.186 -0.015 -0.0125"/>
        </default>
        <default class="z1_gripper_stator_pad_collision_2">
          <geom type="box" size="0.014 0.015 0.004" pos="0.186 0.015 -0.0125"/>
        </default>
        <default class="z1_gripper_mover_collision">
          <geom type="mesh"/>
        </default>
        <default class="z1_gripper_mover_pad_collision_1">
          <geom type="box" size="0.014 0.015 0.004" pos="0.086 -0.015 -0.0055"/>
        </default>
        <default class="z1_gripper_mover_pad_collision_2">
          <geom type="box" size="0.014 0.015 0.004" pos="0.086 0.015 -0.0055"/>
        </default>
      </default>
    </default>
  </default>

  <asset>
    <!-- B2 资源 -->
    <mesh name="base_link" file="base_link.obj"/>
    <mesh name="logo_left" file="logo_left.obj"/>
    <mesh name="logo_right" file="logo_right.obj"/>
    <mesh name="unitree_ladar" file="unitree_ladar.obj"/>
    <mesh name="f_dc_link" file="f_dc_link.obj"/>
    <mesh name="r_dc_link" file="r_dc_link.obj"/>
    <mesh name="fake_imu_link" file="fake_imu_link.STL"/>
    <mesh name="fake_head_Link" file="fake_head_Link.STL"/>
    <mesh name="fake_tail_link" file="fake_tail_link.STL"/>
    <mesh name="FL_hip" file="FL_hip.obj"/>
    <mesh name="FL_thigh" file="FL_thigh.obj"/>
    <mesh name="FL_thigh_protect" file="FL_thigh_protect.obj"/>
    <mesh name="FL_calf" file="FL_calf.obj"/>
    <mesh name="FL_foot" file="FL_foot.obj"/>
    <mesh name="FR_hip" file="FR_hip.obj"/>
    <mesh name="FR_thigh" file="FR_thigh.obj"/>
    <mesh name="FR_thigh_protect" file="FR_thigh_protect.obj"/>
    <mesh name="FR_calf" file="FR_calf.obj"/>
    <mesh name="FR_foot" file="FR_foot.obj"/>
    <mesh name="RL_hip" file="RL_hip.obj"/>
    <mesh name="RL_thigh" file="RL_thigh.obj"/>
    <mesh name="RL_thigh_protect" file="RL_thigh_protect.obj"/>
    <mesh name="RL_calf" file="RL_calf.obj"/>
    <mesh name="RL_foot" file="RL_foot.obj"/>
    <mesh name="RR_hip" file="RR_hip.obj"/>
    <mesh name="RR_thigh" file="RR_thigh.obj"/>
    <mesh name="RR_thigh_protect" file="RR_thigh_protect.obj"/>
    <mesh name="RR_calf" file="RR_calf.obj"/>
    <mesh name="RR_foot" file="RR_foot.obj"/>
    <!-- Z1 资源 -->
    <mesh name="z1_Link00" file="z1_Link00.stl"/>
    <mesh name="z1_Link01" file="z1_Link01.stl"/>
    <mesh name="z1_Link02" file="z1_Link02.stl"/>
    <mesh name="z1_Link03" file="z1_Link03.stl"/>
    <mesh name="z1_Link04" file="z1_Link04.stl"/>
    <mesh name="z1_Link05" file="z1_Link05.stl"/>
    <mesh name="z1_Link06" file="z1_Link06.stl"/>
    <!-- Z1 夹爪资源 -->
    <mesh name="z1_GripperStator" file="z1_GripperStator.stl"/>
    <mesh name="z1_GripperStator_col_1" file="z1_GripperStator_col_1.stl"/>
    <mesh name="z1_GripperStator_col_2" file="z1_GripperStator_col_2.stl"/>
    <mesh name="z1_GripperStator_col_3" file="z1_GripperStator_col_3.stl"/>
    <mesh name="z1_GripperStator_col_4" file="z1_GripperStator_col_4.stl"/>
    <mesh name="z1_GripperStator_col_5" file="z1_GripperStator_col_5.stl"/>
    <mesh name="z1_GripperStator_col_6" file="z1_GripperStator_col_6.stl"/>
    <mesh name="z1_GripperMover" file="z1_GripperMover.stl"/>
    <mesh name="z1_GripperMover_col_1" file="z1_GripperMover_col_1.stl"/>
    <mesh name="z1_GripperMover_col_2" file="z1_GripperMover_col_2.stl"/>
    <mesh name="z1_GripperMover_col_3" file="z1_GripperMover_col_3.stl"/>
    <mesh name="z1_GripperMover_col_4" file="z1_GripperMover_col_4.stl"/>
    <mesh name="z1_GripperMover_col_5" file="z1_GripperMover_col_5.stl"/>
  </asset>

  <worldbody>
    <!-- B2 主体 -->
    <body name="base_link" pos="0 0 0.8" childclass="b2">
      <inertial pos="0.0212868 0.0045819 0.0106169" quat="0.00178111 0.675412 -0.000262894 0.737438" mass="40.8426" diaginertia="1.73786 1.66448 0.343734"/>
      <joint name="floating_base_joint" type="free"/>
      
      <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" rgba="0.7 0.7 0.7 1" mesh="base_link"/>
      <!-- <geom size="0.2 0.1 0.075" type="box" rgba="0.7 0.7 0.7 1" class="collision_b2"/> -->
      <site name="imu" pos="0 -0.02341 0.04927"/>


      <!-- B2 腿部 (缩减展示，保留层级) -->
      <body name="FL_hip" pos="0.3285 0.072 0">
        <joint name="FL_hip_joint" axis="1 0 0" range="-0.87 0.87"/>
        <geom type="mesh" mesh="FL_hip"/>
        <body name="FL_thigh" pos="0 0.11973 0">
          <joint name="FL_thigh_joint" axis="0 1 0" range="-0.94 4.69"/>
          <geom type="mesh" mesh="FL_thigh"/>
          <body name="FL_calf" pos="0 -8.6984e-05 -0.35">
            <joint name="FL_calf_joint" axis="0 1 0" range="-2.82 -0.43"/>
            <geom type="mesh" mesh="FL_calf"/>
            <geom size="0.032" pos="0 0 -0.35" type="sphere" class="collision_b2"/>
          </body>
        </body>
      </body>

      <body name="FR_hip" pos="0.3285 -0.072 0">
        <joint name="FR_hip_joint" axis="1 0 0" range="-0.87 0.87"/>
        <geom type="mesh" mesh="FR_hip"/>
        <body name="FR_thigh" pos="0 -0.11973 0">
          <joint name="FR_thigh_joint" axis="0 1 0" range="-0.94 4.69"/>
          <geom type="mesh" mesh="FR_thigh"/>
          <body name="FR_calf" pos="0 8.6986e-05 -0.35">
            <joint name="FR_calf_joint" axis="0 1 0" range="-2.82 -0.43"/>
            <geom type="mesh" mesh="FR_calf"/>
            <geom size="0.032" pos="0 0 -0.35" type="sphere" class="collision_b2"/>
          </body>
        </body>
      </body>

      <body name="RL_hip" pos="-0.3285 0.072 0">
        <joint name="RL_hip_joint" axis="1 0 0" range="-0.87 0.87"/>
        <geom type="mesh" mesh="RL_hip"/>
        <body name="RL_thigh" pos="0 0.11973 0">
          <joint name="RL_thigh_joint" axis="0 1 0" range="-0.94 4.69"/>
          <geom type="mesh" mesh="RL_thigh"/>
          <body name="RL_calf" pos="0 -8.6984e-05 -0.35">
            <joint name="RL_calf_joint" axis="0 1 0" range="-2.82 -0.43"/>
            <geom type="mesh" mesh="RL_calf"/>
            <geom size="0.032" pos="0 0 -0.35" type="sphere" class="collision_b2"/>
          </body>
        </body>
      </body>

      <body name="RR_hip" pos="-0.3285 -0.072 0">
        <joint name="RR_hip_joint" axis="1 0 0" range="-0.87 0.87"/>
        <geom type="mesh" mesh="RR_hip"/>
        <body name="RR_thigh" pos="0 -0.11973 0">
          <joint name="RR_thigh_joint" axis="0 1 0" range="-0.94 4.69"/>
          <geom type="mesh" mesh="RR_thigh"/>
          <body name="RR_calf" pos="0 8.6986e-05 -0.35">
            <joint name="RR_calf_joint" axis="0 1 0" range="-2.82 -0.43"/>
            <geom type="mesh" mesh="RR_calf"/>
            <geom size="0.032" pos="0 0 -0.35" type="sphere" class="collision_b2"/>
          </body>
        </body>
      </body>

      <!-- ======================================================================================= -->
      <!-- Z1 机械臂安装 (带夹爪) -->
      <!-- ======================================================================================= -->
      <body name="link00" pos="0.2 0 0.25" childclass="z1">
        <inertial pos="-0.00334984 -0.00013615 0.0249584" quat="-0.00692194 0.682592 0.00133293 0.730766" mass="0.472475" diaginertia="0.000531375 0.000415207 0.000378658"/>
        <geom class="visual_z1" mesh="z1_Link00"/>
        <geom size="0.0325 0.0255" pos="0 0 0.0255" class="collision_z1"/>
        <body name="link01" pos="0 0 0.0585">
          <joint name="joint1" axis="0 0 1" range="-2.61799 2.61799"/>
          <geom class="visual_z1" mesh="z1_Link01"/>
          <body name="link02" pos="0 0 0.045">
            <joint name="joint2" axis="0 1 0" range="0 2.96706" damping="2"/>
            <geom class="visual_z1" mesh="z1_Link02"/>
            <geom size="0.0325 0.051" quat="1 1 0 0" class="collision_z1"/>
            <body name="link03" pos="-0.35 0 0">
              <joint name="joint3" axis="0 1 0" range="-2.87979 0"/>
              <geom class="visual_z1" mesh="z1_Link03"/>
              <body name="link04" pos="0.218 0 0.057">
                <joint name="joint4" axis="0 1 0" range="-1.51844 1.51844"/>
                <geom class="visual_z1" mesh="z1_Link04"/>
                <body name="link05" pos="0.07 0 0">
                  <joint name="joint5" axis="0 0 1" range="-1.3439 1.3439"/>
                  <geom class="visual_z1" mesh="z1_Link05"/>
                  <body name="link06" pos="0.0492 0 0">
                    <joint name="joint6" axis="1 0 0" range="-2.79253 2.79253"/>
                    <geom class="visual_z1" mesh="z1_Link06"/>
                    <geom size="0.0325 0.0255" pos="0.0255 0 0" quat="1 0 1 0" class="collision_z1"/>
                    
                    <!-- 夹爪固定部分 (Stator) -->
                    <geom pos="0.051 0 0" type="mesh" mesh="z1_GripperStator" class="visual_z1"/>
                    <geom class="z1_gripper_stator_collision" mesh="z1_GripperStator_col_1"/>
                    <geom class="z1_gripper_stator_collision" mesh="z1_GripperStator_col_2"/>
                    <geom class="z1_gripper_stator_collision" mesh="z1_GripperStator_col_3"/>
                    <geom class="z1_gripper_stator_collision" mesh="z1_GripperStator_col_4"/>
                    <geom class="z1_gripper_stator_collision" mesh="z1_GripperStator_col_5"/>
                    <geom class="z1_gripper_stator_collision" mesh="z1_GripperStator_col_6"/>
                    <geom class="z1_gripper_stator_pad_collision_1"/>
                    <geom class="z1_gripper_stator_pad_collision_2"/>

                    <!-- 夹爪活动部分 (Mover) -->
                    <body name="gripperMover" pos="0.1 0 0">
                      <inertial pos="0.0132063 0.00476708 0.00380534" quat="0.0631093 0.669067 -0.0615783 0.737953" mass="0.276213" diaginertia="0.000359044 0.000270888 0.000172378"/>
                      <geom type="mesh" mesh="z1_GripperMover" class="visual_z1"/>
                      <geom class="z1_gripper_mover_collision" mesh="z1_GripperMover_col_1"/>
                      <geom class="z1_gripper_mover_collision" mesh="z1_GripperMover_col_2"/>
                      <geom class="z1_gripper_mover_collision" mesh="z1_GripperMover_col_3"/>
                      <geom class="z1_gripper_mover_collision" mesh="z1_GripperMover_col_4"/>
                      <geom class="z1_gripper_mover_collision" mesh="z1_GripperMover_col_5"/>
                      <geom class="z1_gripper_mover_pad_collision_1"/>
                      <geom class="z1_gripper_mover_pad_collision_2"/>
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
       </body>
      <!-- ======================================================================================= -->

    </body>
  </worldbody>

  <actuator>
    <!-- B2 电机 (12个) -->
    <motor class="b2" name="FL_hip" joint="FL_hip_joint" ctrlrange="-200 200"/>
    <motor class="b2" name="FL_thigh" joint="FL_thigh_joint" ctrlrange="-200 200"/>
    <motor class="b2" name="FL_calf" joint="FL_calf_joint" ctrlrange="-300 300"/>
    <motor class="b2" name="FR_hip" joint="FR_hip_joint" ctrlrange="-200 200"/>
    <motor class="b2" name="FR_thigh" joint="FR_thigh_joint" ctrlrange="-200 200"/>
    <motor class="b2" name="FR_calf" joint="FR_calf_joint" ctrlrange="-300 300"/>
    <motor class="b2" name="RL_hip" joint="RL_hip_joint" ctrlrange="-200 200"/>
    <motor class="b2" name="RL_thigh" joint="RL_thigh_joint" ctrlrange="-200 200"/>
    <motor class="b2" name="RL_calf" joint="RL_calf_joint" ctrlrange="-300 300"/>
    <motor class="b2" name="RR_hip" joint="RR_hip_joint" ctrlrange="-200 200"/>
    <motor class="b2" name="RR_thigh" joint="RR_thigh_joint" ctrlrange="-200 200"/>
    <motor class="b2" name="RR_calf" joint="RR_calf_joint" ctrlrange="-300 300"/>

    <!-- Z1 机械臂电机 (6个) -->
    <motor class="z1" name="z1_motor1" joint="joint1" ctrlrange= "-40.0 40.0"/>
    <motor class="z1" name="z1_motor2" joint="joint2" ctrlrange="-40.0 40.0" />
    <motor class="z1" name="z1_motor3" joint="joint3" ctrlrange="-20.0 20.0"/>
    <motor class="z1" name="z1_motor4" joint="joint4" ctrlrange="-10.0 10.0"/>
    <motor class="z1" name="z1_motor5" joint="joint5" ctrlrange="-5.0 5.0"/>
    <motor class="z1" name="z1_motor6" joint="joint6" ctrlrange="-5.0 5.0"/>

    <!-- Z1 夹爪电机 (1个) -->
  </actuator>

</mujoco>